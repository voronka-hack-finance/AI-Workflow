APP_ENV=development

RABBITMQ_URL=amqp://finance_ai:finance_ai@rabbitmq:5672/
RABBITMQ_WORKFLOW_QUEUE=ai.workflow.tasks
RABBITMQ_WORKFLOW_RESULT_QUEUE=ai.workflow.results
RABBITMQ_PREFETCH_COUNT=3

AI_WORKFLOW_SERVICE_NAME=ai-workflow-service
AI_WORKFLOW_PORT=8010
AI_WORKFLOW_SERVICE_PORT=8010
LLM_INTENT_PARSER_SERVICE_PORT=8011
AI_CONTEXT_BUILDER_SERVICE_PORT=8012
ANALYTICS_SERVICE_NAME=analytics-service
ANALYTICS_SERVICE_PORT=8013
ANALYTICS_RULES_VERSION=v1.0
ANALYTICS_DEFAULT_CURRENCY=RUB
LLM_RESPONSE_AGENT_SERVICE_PORT=8014

LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=

INTENT_PARSER_SERVICE_NAME=llm-intent-parser-service
INTENT_PARSER_PORT=8011
# Docker dev: LM Studio on host machine. Local uvicorn: use http://127.0.0.1:1234/v1 in llm-intent-parser-service/.env
# Tests/CI only: INTENT_PARSER_LLM_PROVIDER=mock
INTENT_PARSER_LLM_PROVIDER=openai_compatible
INTENT_PARSER_LLM_MODEL=qwen2.5-7b-instruct
OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_COMPATIBLE_API_KEY=local
INTENT_PARSER_LLM_TEMPERATURE=0.1
INTENT_PARSER_MAX_OUTPUT_TOKENS=1200
INTENT_PARSER_LLM_TIMEOUT_SECONDS=120
# Few-shot pairs: 0=system prompt only (local 7B), 3=compact, omit or empty=all 9
INTENT_PARSER_FEW_SHOT_LIMIT=0

AI_WORKFLOW_MAX_CONCURRENT_RUNS=3
AI_WORKFLOW_HTTP_TIMEOUT_SECONDS=30
AI_WORKFLOW_HTTP_MAX_RETRIES=2
INTENT_PARSER_HTTP_TIMEOUT_SECONDS=150
RESPONSE_AGENT_HTTP_TIMEOUT_SECONDS=300
AI_WORKFLOW_ENABLE_HTTP_TRIGGER=true

INTENT_PARSER_SERVICE_URL=http://llm-intent-parser-service:8011
CONTEXT_BUILDER_SERVICE_URL=http://ai-context-builder-service:8012
CONTEXT_BUILDER_DATA_PROVIDER=rabbitmq

# Backend-hackathon RabbitMQ (host). Used by ai-context-builder-service for backend data jobs.
# Prerequisite: backend-hackathon docker-compose up (RabbitMQ :5673, backend-data-worker, gateway :8081).
BACKEND_RABBITMQ_URL=amqp://guest:guest@host.docker.internal:5673/
RABBITMQ_BACKEND_DATA_REQUEST_QUEUE=ai.backend.data.requests
RABBITMQ_BACKEND_DATA_RESPONSE_QUEUE=ai.context_builder.backend_data.responses
CONTEXT_BUILDER_BACKEND_DATA_TIMEOUT_SECONDS=30

# Optional: only for legacy ai-workflow backend-data-worker in gateway HTTP mode.
# JWT user_id MUST match workflow user_id. Prefer backend-hackathon RPC worker instead.
BACKEND_GATEWAY_BASE_URL=http://host.docker.internal:8081
BACKEND_DEV_ACCESS_TOKEN=
ANALYTICS_SERVICE_URL=http://analytics-service:8013
RESPONSE_AGENT_SERVICE_URL=http://llm-response-agent-service:8014
RESPONSE_AGENT_SERVICE_NAME=llm-response-agent-service
RESPONSE_AGENT_PORT=8014
# Tests/CI only: RESPONSE_AGENT_LLM_PROVIDER=mock
RESPONSE_AGENT_LLM_PROVIDER=openai_compatible
RESPONSE_AGENT_LLM_MODEL=qwen2.5-7b-instruct
RESPONSE_AGENT_LLM_TEMPERATURE=0.2
RESPONSE_AGENT_MAX_OUTPUT_TOKENS=3000
RESPONSE_AGENT_LLM_TIMEOUT_SECONDS=120
RESPONSE_AGENT_MAX_SELECTED_AGENTS=3
