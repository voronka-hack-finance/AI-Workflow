# Production — template for docker-compose.prod.yml.
# GitHub Actions builds .env.production from this file; override via secret AI_PRODUCTION_ENV.

APP_ENV=production

# GHCR images
REGISTRY=ghcr.io
IMAGE_OWNER=voronka-hack-finance
IMAGE_TAG=latest

# External backend RabbitMQ (zanachka) — workflow + backend data on one broker :5672
# Backend env mapping: RABBITMQ_TASK_QUEUE -> RABBITMQ_WORKFLOW_QUEUE,
#                      RABBITMQ_RESULT_QUEUE -> RABBITMQ_WORKFLOW_RESULT_QUEUE
RABBITMQ_URL=amqp://finance_ai:finance_ai@zanachka.avenir-team.ru:5672/
RABBITMQ_WORKFLOW_QUEUE=ai.workflow.tasks
RABBITMQ_WORKFLOW_RESULT_QUEUE=ai.workflow.results
RABBITMQ_PREFETCH_COUNT=3

BACKEND_RABBITMQ_URL=amqp://finance_ai:finance_ai@zanachka.avenir-team.ru:5672/
RABBITMQ_BACKEND_DATA_REQUEST_QUEUE=ai.backend.data.requests
RABBITMQ_BACKEND_DATA_RESPONSE_QUEUE=ai.context_builder.backend_data.responses
CONTEXT_BUILDER_BACKEND_DATA_TIMEOUT_SECONDS=30

# Inter-service URLs (Docker network)
INTENT_PARSER_SERVICE_URL=http://llm-intent-parser-service:8011
CONTEXT_BUILDER_SERVICE_URL=http://ai-context-builder-service:8012
ANALYTICS_SERVICE_URL=http://analytics-service:8013
RESPONSE_AGENT_SERVICE_URL=http://llm-response-agent-service:8014

# Workflow service
AI_WORKFLOW_ENABLE_RABBITMQ_CONSUMER=true
AI_WORKFLOW_ENABLE_HTTP_TRIGGER=true
AI_WORKFLOW_MAX_CONCURRENT_RUNS=3
AI_WORKFLOW_HTTP_TIMEOUT_SECONDS=30
AI_WORKFLOW_HTTP_MAX_RETRIES=2
INTENT_PARSER_HTTP_TIMEOUT_SECONDS=150
RESPONSE_AGENT_HTTP_TIMEOUT_SECONDS=300

# Analytics
ANALYTICS_RULES_VERSION=v1.0
ANALYTICS_DEFAULT_CURRENCY=RUB

# LLM via Ollama container
OPENAI_COMPATIBLE_BASE_URL=http://ollama:11434/v1
OPENAI_COMPATIBLE_API_KEY=ollama

INTENT_PARSER_LLM_PROVIDER=openai_compatible
INTENT_PARSER_LLM_MODEL=qwen3:14b-q4_K_M
INTENT_PARSER_LLM_TIMEOUT_SECONDS=120
INTENT_PARSER_FEW_SHOT_LIMIT=0

RESPONSE_AGENT_LLM_PROVIDER=openai_compatible
RESPONSE_AGENT_LLM_MODEL=qwen3:14b-q4_K_M
RESPONSE_AGENT_LLM_TIMEOUT_SECONDS=120
RESPONSE_AGENT_MAX_OUTPUT_TOKENS=3000
RESPONSE_AGENT_MAX_SELECTED_AGENTS=3
