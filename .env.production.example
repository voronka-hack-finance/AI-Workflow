# Docker compose dev — backend data via backend-hackathon RabbitMQ (:5673) and gateway (:8081).
# Prerequisite: backend-hackathon docker-compose running (gateway + RabbitMQ on host).

CONTEXT_BUILDER_SERVICE_URL=http://ai-context-builder-service:8012
CONTEXT_BUILDER_DATA_PROVIDER=rabbitmq

BACKEND_RABBITMQ_URL=amqp://guest:guest@host.docker.internal:5673/
BACKEND_GATEWAY_BASE_URL=http://host.docker.internal:8081

OPENAI_COMPATIBLE_BASE_URL=http://ollama:11434/v1
OPENAI_COMPATIBLE_API_KEY=ollama

INTENT_PARSER_LLM_PROVIDER=openai_compatible
INTENT_PARSER_LLM_MODEL=qwen3:14b-q4_K_M

RESPONSE_AGENT_LLM_PROVIDER=openai_compatible
RESPONSE_AGENT_LLM_MODEL=qwen3:14b-q4_K_M

