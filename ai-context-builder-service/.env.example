APP_ENV=development
SERVICE_PORT=8012

# mock = fixtures (tests); rabbitmq = real backend via RabbitMQ jobs
CONTEXT_BUILDER_DATA_PROVIDER=rabbitmq
CONTEXT_BUILDER_BACKEND_DATA_TIMEOUT_SECONDS=30

# RabbitMQ from backend-hackathon docker-compose (host port 5673, NOT 5672)
RABBITMQ_URL=amqp://guest:guest@localhost:5673/
RABBITMQ_BACKEND_DATA_REQUEST_QUEUE=ai.backend.data.requests
RABBITMQ_BACKEND_DATA_RESPONSE_QUEUE=ai.context_builder.backend_data.responses

# Gateway URL (http://localhost:8081) is NOT here on purpose.
# Context Builder must not call backend HTTP — only RabbitMQ jobs.
# Backend consumer + gateway auth are configured in the backend repository.
